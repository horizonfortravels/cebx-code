<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    RewriteRule ^public/(.*)$ /$1 [R=301,L]

    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    RewriteRule (^|/)\.(?!well-known/) - [F,L]

    RewriteRule ^storage/(.*)$ index.php [L]

    RewriteRule ^(app|bootstrap|config|database|resources|routes|tests|vendor|node_modules|docs|tmp)(/|$) - [F,L]
    RewriteRule ^(artisan|composer\.(json|lock)|package(-lock)?\.json|phpunit\.xml|Dockerfile|docker-compose\.yml|playwright\.config\.js|README\.md|FR-.*\.md|\.env(\..*)?|\.gitattributes|\.gitignore|\.phpunit\.result\.cache)$ - [F,L]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
