FEATURE_SEA_FREIGHT=true
FEATURE_AIR_FREIGHT=true
FEATURE_LAND_TRANSPORT=true
FEATURE_CUSTOMS_CLEARANCE=true
FEATURE_PHASE2_CRUD=true
FEATURE_FINANCIAL_AUTO_INVOICE=true
FEATURE_REFUND_WORKFLOW=true

FEATURE_AI_ANOMALY=false
FEATURE_AI_DELAY=false
FEATURE_AI_RISK=false
FEATURE_SANDBOX_MODE=false
FEATURE_DEMO_DATA=false

ADDRESS_VALIDATION_DRIVER=local_rules

