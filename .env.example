APP_NAME="Shipping Gateway"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://your-server:8000
APP_TIMEZONE=Asia/Riyadh

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=shipping_gateway
DB_USERNAME=shipping
DB_PASSWORD=secret

CACHE_DRIVER=redis
CACHE_PREFIX=sg_cache_
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE=shipping-gateway

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=${APP_URL}
SANCTUM_STATEFUL_DOMAINS=
SANCTUM_TOKEN_PREFIX=

FEATURE_CARRIER_ARAMEX=false
FEATURE_CARRIER_DHL=false
FEATURE_CARRIER_FEDEX=false
FEATURE_CARRIER_JNT=false
FEATURE_CARRIER_SMSA=false

FEATURE_PAYMENT_MOYASAR=false
FEATURE_PAYMENT_STRIPE=false
FEATURE_PAYMENT_STCPAY=false
FEATURE_PAYMENT_APPLEPAY=false

FEATURE_CUSTOMS_FASAH=false
FEATURE_CUSTOMS_ZATCA=false

FEATURE_ECOMMERCE_SALLA=false
FEATURE_ECOMMERCE_ZID=false
FEATURE_ECOMMERCE_SHOPIFY=false

FEATURE_NOTIFY_EMAIL=false
FEATURE_NOTIFY_SMS=false
